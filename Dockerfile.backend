FROM node:22-bookworm-slim AS builder

# Enable corepack for pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy lockfiles and workspace configs
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# We need to copy the entire workspace to resolve workspace:* dependencies
# since `db` and `api-zod` etc are used by `api-server`.
# A better approach for huge monorepos is to use turbo or specific copy,
# but for this size copying everything is fine.
COPY . .

# Install dependencies (frozen-lockfile ensures deterministic builds)
RUN pnpm install --frozen-lockfile

# Build the api-server
# Note: the build script in api-server expects to run from within artifacts/api-server
# but the root pnpm run typecheck && pnpm -r run build handles this cleanly.
# Alternatively, we can just run it for api-server specifically.
RUN pnpm --filter "@workspace/api-server" run build

# Runner stage
FROM node:22-bookworm-slim AS runner

WORKDIR /app

ENV NODE_ENV=production

# Copy built assets
COPY --from=builder /app/artifacts/api-server/dist ./dist
# The esbuild output bundles most things, but it externalizes some modules like pg, better-sqlite3, etc.
# So we need node_modules. We can copy the entire built workspace or just the prod dependencies.
# The simplest approach is to copy the built monorepo, since pnpm handles workspace symlinks.
# But an even simpler way is to keep the entire /app from builder for the backend,
# since esbuild didn't bundle tesseract.js, pdf-parse, etc.
# Let's adjust to copy the entire /app to avoid missing native modules.

# So actually, we just use a single stage or copy everything from builder
# since `api-server` has externalized dependencies.
COPY --from=builder /app /app

WORKDIR /app/artifacts/api-server

# Expose port 4000 (standard for the API server based on vite config proxy)
EXPOSE 4000

CMD ["node", "--enable-source-maps", "./dist/index.mjs"]
